# =========================
# 1) REQUIRED: Telegram API
# =========================
API_ID=123456
API_HASH=your_api_hash_here

# Session file prefix (creates *.session files)
SESSION_NAME=autoforwarder

# Login method: phone or qr
AUTH_MODE=phone

# ======================
# 2) Forwarding route
# ======================
# Comma-separated source chats (username/link/numeric id)
SOURCE_CHATS=@source_chat_1,@source_chat_2

# Single target chat (username/link/numeric id)
TARGET_CHAT=@target_chat

# Enable/disable forwarding from SOURCE_CHATS to target
# true  = forwarding works
# false = forwarding handlers are disabled
# If all delivery switches are false (FORWARDING_ENABLED, EMAIL_FORWARDING_ENABLED, PM_ALERTS_ENABLED, EMAIL_PM_ALERTS_BATCH_ENABLED),
# script exits with "Nothing to run"
FORWARDING_ENABLED=true

# Skip your own outgoing messages from source chats
SKIP_OUTGOING=true

# ======================
# 3) Delivery mode block
# ======================
# user = send from your account
# bot  = send from bot account
DELIVERY_MODE=user

# Required when DELIVERY_MODE=bot
# Also required when PM_ALERTS_ENABLED=true
BOT_TOKEN=

# Optional when DELIVERY_MODE=bot
# If empty, TARGET_CHAT is used
BOT_TARGET_CHAT=

# =========================
# 4) Edit sync map storage
# =========================
# Map files for source->target message ids (for edit sync)
MESSAGE_MAP_FILE_USER=autoforwarder_message_map_user.json
MESSAGE_MAP_FILE_BOT=autoforwarder_message_map_bot.json

# Delete map records older than N days (0 disables cleanup)
MESSAGE_MAP_TTL_DAYS=7

# =========================
# 5) Optional sender filter
# =========================
# Global filter for all source chats (comma-separated refs)
# Example: ALLOWED_SENDERS=@boss,123456789
ALLOWED_SENDERS=

# Per-chat sender filters as JSON (priority over ALLOWED_SENDERS)
# Example: CHAT_ALLOWED_SENDERS={"@work_chat":["@boss","123456789"],"-1001234567890":["@lead"]}
CHAT_ALLOWED_SENDERS=

# ======================
# 6) Optional PM alerts
# ======================
# Telegram PM alerts delivery
PM_ALERTS_ENABLED=false

# Optional PM alerts target chat
# Used only when PM_ALERTS_ENABLED=true
# If empty, BOT_TARGET_CHAT or TARGET_CHAT is used
PM_ALERT_TARGET_CHAT=

# Telegram PM alerts: one alert per sender per N minutes (0 disables cooldown)
# Not used by EMAIL_PM_ALERTS_BATCH_ENABLED mode
PM_ALERT_COOLDOWN_MINUTES=60

# Alert language: eng or ru
PM_ALERTS_LANG=eng

# PM alerts cooldown state file
PM_ALERTS_FILE=autoforwarder_pm_alerts.json

# Optional: require silence since your last own PM message
# true  = PM alert is sent only if you were silent in that chat for N minutes
# false = this extra check is disabled
PM_ALERT_REQUIRE_MY_SILENCE=false
PM_ALERT_MIN_SILENCE_AFTER_MY_MESSAGE_MINUTES=30
PM_ALERT_MY_ACTIVITY_FILE=autoforwarder_pm_alerts_my_activity.json

# Auto-delete for PM alert messages
# true  = delete old PM alerts on schedule
# false = keep PM alert messages
# Requires PM_ALERTS_ENABLED=true
# If PM_ALERTS_ENABLED=false, PM_ALERTS_AUTO_DELETE_ENABLED must be false
PM_ALERTS_AUTO_DELETE_ENABLED=false

# Daily delete time (server local time), HH:MM
PM_ALERTS_AUTO_DELETE_TIME=05:00

# Delete PM alerts older than this many hours
# Maximum allowed value: 48
PM_ALERTS_AUTO_DELETE_AFTER_HOURS=24

# File with PM alert message ids for auto-delete
PM_ALERTS_AUTO_DELETE_FILE=autoforwarder_pm_alerts_messages.json

# Do not send PM alerts from these private chats/users
# Example: PM_ALERTS_EXCLUDE_CHATS=@john,123456789
PM_ALERTS_EXCLUDE_CHATS=

# ===========================
# 7) Optional email delivery
# ===========================
# Email copy of forwarded SOURCE_CHATS messages
EMAIL_FORWARDING_ENABLED=false

# Debounced email PM alerts batch (collect messages and send one email after inactivity)
# Works with or without PM_ALERTS_ENABLED
EMAIL_PM_ALERTS_BATCH_ENABLED=false

# Inactivity window in minutes for email PM alerts batch
# Each new message from the same sender resets the timer
EMAIL_PM_ALERTS_BATCH_MINUTES=10

# JSON file for pending email PM alert batches
# Entries are removed right after successful email send
EMAIL_PM_ALERTS_BATCH_FILE=autoforwarder_email_pm_alerts_batch.json

# SMTP configuration (required if any email flag above is true)
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_USE_TLS=true
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM=
# Comma-separated recipients
EMAIL_TO=
