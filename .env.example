API_ID=123456
API_HASH=your_api_hash_here

# Optional: file name for Telethon session (without extension)
SESSION_NAME=autoforwarder

# Auth mode: phone or qr
AUTH_MODE=phone

# Comma-separated chat references: usernames, links, or numeric IDs
SOURCE_CHATS=@source_chat_1,@source_chat_2

# Single target chat reference: @username, link, or numeric ID
TARGET_CHAT=@target_chat

# true/false - skip your own outgoing messages from source chats
SKIP_OUTGOING=true

# Optional: global sender filter for all SOURCE_CHATS (comma-separated)
# Example: ALLOWED_SENDERS=@boss,123456789
ALLOWED_SENDERS=

# Optional: per-chat sender filters as JSON (overrides ALLOWED_SENDERS for matched chats)
# Example: CHAT_ALLOWED_SENDERS={"@work_chat":["@boss","123456789"],"-1001234567890":["@lead"]}
CHAT_ALLOWED_SENDERS=
