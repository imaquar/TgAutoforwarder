API_ID=123456
API_HASH=your_api_hash_here

# Optional: file name for Telethon session (without extension)
SESSION_NAME=autoforwarder

# Delivery mode:
# - user: send to target chat from your user account
# - bot: send to target chat from BOT_TOKEN account
DELIVERY_MODE=user

# Auth mode: phone or qr
AUTH_MODE=phone

# Comma-separated chat references: usernames, links, or numeric IDs
SOURCE_CHATS=@source_chat_1,@source_chat_2

# Single target chat reference: @username, link, or numeric ID
TARGET_CHAT=@target_chat

# Required when DELIVERY_MODE=bot or PM_ALERTS_ENABLED=true
BOT_TOKEN=

# Optional when DELIVERY_MODE=bot; if empty, TARGET_CHAT is used
BOT_TARGET_CHAT=

# Optional: message map file for DELIVERY_MODE=bot
MESSAGE_MAP_FILE_BOT=autoforwarder_message_map_bot.json

# Optional: message map file for DELIVERY_MODE=user
MESSAGE_MAP_FILE_USER=autoforwarder_message_map_user.json

# Optional: delete mapping records older than N days (0 disables cleanup)
MESSAGE_MAP_TTL_DAYS=7

# Optional PM alerts (private incoming messages only)
# Bot sends (by language): "<Name> wrote a new message" or "<Name> написал(-а) новое сообщение"
PM_ALERTS_ENABLED=false

# Optional target for PM alerts; if empty, BOT_TARGET_CHAT (or TARGET_CHAT) is used
PM_ALERT_TARGET_CHAT=

# Optional cooldown per sender in minutes (0 disables cooldown)
PM_ALERT_COOLDOWN_MINUTES=60

# Optional PM alerts language: eng or ru
PM_ALERTS_LANG=eng

# Optional file to persist PM alert cooldown state
PM_ALERTS_FILE=autoforwarder_pm_alerts.json

# Optional: do not send PM alerts for these private chats/users (comma-separated refs)
# Example: PM_ALERTS_EXCLUDE_CHATS=@john,123456789
PM_ALERTS_EXCLUDE_CHATS=

# true/false - skip your own outgoing messages from source chats
SKIP_OUTGOING=true

# Optional: global sender filter for all SOURCE_CHATS (comma-separated)
# Example: ALLOWED_SENDERS=@boss,123456789
ALLOWED_SENDERS=

# Optional: per-chat sender filters as JSON (overrides ALLOWED_SENDERS for matched chats)
# Example: CHAT_ALLOWED_SENDERS={"@work_chat":["@boss","123456789"],"-1001234567890":["@lead"]}
CHAT_ALLOWED_SENDERS=
